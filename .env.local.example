# PostHog Analytics (get these from https://us.posthog.com)
NEXT_PUBLIC_POSTHOG_KEY=phc_your_project_api_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Firebase Auth + Firestore (Firebase Console → Project Settings → General)
# Required for Google sign-in and cross-device premium sync.
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_APP_ID=1:1234567890:web:abcdef

# Stripe (server-only — never NEXT_PUBLIC)
# Required for /api/verify-purchase and /api/unlock.
STRIPE_SECRET_KEY=sk_live_or_test_key
PREMIUM_TOKEN_SECRET=long_random_string_for_signing_premium_tokens

# Admin override for premium access (comma-separated emails)
ADMIN_EMAILS=you@example.com

# Upstash Redis (only used by social auto-post state; core app works without it)
KV_REST_API_URL=https://your-db.upstash.io
KV_REST_API_TOKEN=your_upstash_token

# Social auto-post pipeline (optional — only if running the daily cron post)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=
FB_PAGE_ID=
FB_PAGE_ACCESS_TOKEN=
OPENAI_API_KEY=
CRON_SECRET=
